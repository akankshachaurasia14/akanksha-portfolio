# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real secrets.

# Port the server listens on (Render sets this automatically in production)
PORT=5000

# MongoDB connection string (MongoDB Atlas free tier works great).
# Leave blank to run with read-only fallback data (no saving/contact storage).
MONGODB_URI=

# Comma-separated list of frontend origins allowed to call this API.
# Include your Vercel URL once deployed, and localhost for local dev.
ALLOWED_ORIGINS=http://localhost:5173
